{
  "name": "claude-compact-guard",
  "version": "1.0.0",
  "description": "Saves critical context before /compact destroys it. Reinjects after. Zero context loss.",
  "author": {
    "name": "celeritas-stack"
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/pre-compact.js",
            "timeout": 8000,
            "async": false
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/post-compact.js",
            "timeout": 8000,
            "async": false
          }
        ]
      }
    ]
  }
}
